/* Check for updates dialog */
"Check for updates automatically?" = "自动检查更新？";
"Should %1$@ automatically check for updates? You can always check for updates manually from the %1$@ menu." = "是否让 %1$@ 自动检查更新？你也可以随时从 %1$@ 菜单手动检查。";
"Automatically download and install updates" = "自动下载并安装更新";
"Don't Check" = "不检查";
"Check Automatically" = "自动检查";

/* Update available */
"A new version of %@ is available!" = "%@ 有新版本可用！";
"%@ %@ is now available—you have %@. Would you like to download it now?" = "%@ %@ 现已推出，你当前版本为 %@。是否立即下载？";
"Skip This Version" = "跳过此版本";
"Remind Me Later" = "稍后提醒";
"Install Update" = "安装更新";
"Install and Relaunch" = "安装并重启";

/* Checking */
"Checking for updates…" = "正在检查更新…";
"Downloading update…" = "正在下载更新…";
"Extracting update…" = "正在解压更新…";
"Installing update…" = "正在安装更新…";
"You're up to date!" = "已是最新版本！";
"%@ %@ is currently the newest version available." = "当前 %@ %@ 已是最新版本。";

/* Errors */
"Update Error!" = "更新出错！";
"An error occurred in retrieving update information. Please try again later." = "获取更新信息时出错，请稍后重试。";
"Cancel" = "取消";
